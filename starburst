#!/usr/bin/env bash
# Run Starburst CLI from CLI_JAR in repo .env (same idea as: alias starburst="java -jar $CLI_JAR")
# Resolves symlinks so a global link in ~/.local/bin still finds this repo and .env.
set -euo pipefail
_script="${BASH_SOURCE[0]}"
REPO_ROOT="$(python3 -c 'import os, sys; print(os.path.dirname(os.path.realpath(sys.argv[1])))' "$_script")"
ENV_FILE="${ENV_FILE:-$REPO_ROOT/.env}"
if [[ ! -f "$ENV_FILE" ]]; then
  echo "Missing $ENV_FILE — create it with CLI_JAR and server credentials." >&2
  exit 1
fi
set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a
if [[ -z "${CLI_JAR:-}" ]]; then
  echo "CLI_JAR is not set in $ENV_FILE" >&2
  exit 1
fi
cd "$REPO_ROOT"

# The Starburst CLI treats HTTP 204 from the publish POST as failure ("ERROR: HTTP 204").
# SEP returns 204 No Content for a successful trigger. Delegate publish to the REST script.
if [[ "${1:-}" == "data-product" && "${2:-}" == "publish" ]]; then
  _publish_sh="$REPO_ROOT/.agents/skills/starburst-data-products/scripts/publish.sh"
  _pid=""
  _dname=""
  _pname=""
  _args=("$@")
  set -- "${_args[@]:2}"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id=*) _pid="${1#*=}"; shift ;;
      --id) _pid="$2"; shift 2 ;;
      --domain=*) _dname="${1#*=}"; shift ;;
      --domain) _dname="$2"; shift 2 ;;
      --name=*) _pname="${1#*=}"; shift ;;
      --name) _pname="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  if [[ -z "$_pid" && -n "$_dname" && -n "$_pname" ]]; then
    _domain_id="$(
      curl -sk -u "$STARBURST_USER:$STARBURST_PASSWORD" \
        -H "X-Trino-Role: system=ROLE{$ROLE}" \
        "$SERVER/api/v1/dataProduct/domains" | python3 -c "
import json, sys
raw = json.load(sys.stdin)
items = raw if isinstance(raw, list) else raw.get('domains', raw.get('data', []))
want = sys.argv[1]
for x in items:
    if x.get('name') == want:
        print(x.get('id') or '')
        sys.exit(0)
sys.exit(1)
" "$_dname"
    )" || true
    if [[ -z "$_domain_id" ]]; then
      echo "Could not resolve data domain name: $_dname" >&2
      exit 1
    fi
    _pid="$(
      curl -sk -u "$STARBURST_USER:$STARBURST_PASSWORD" \
        -H "X-Trino-Role: system=ROLE{$ROLE}" \
        "$SERVER/api/v1/dataProduct/products" | python3 -c "
import json, sys
raw = json.load(sys.stdin)
items = raw if isinstance(raw, list) else raw.get('products', raw.get('data', []))
want_domain, want_name = sys.argv[1], sys.argv[2]
for p in items:
    n = p.get('name') or (p.get('metadata') or {}).get('name')
    if n == want_name and p.get('dataDomainId') == want_domain:
        print(p.get('id') or '')
        sys.exit(0)
sys.exit(1)
" "$_domain_id" "$_pname"
    )" || true
    if [[ -z "$_pid" ]]; then
      echo "Could not resolve product name in domain: $_pname / $_dname" >&2
      exit 1
    fi
  fi
  if [[ -n "$_pid" ]]; then
    exec bash "$_publish_sh" "$_pid"
  fi
fi

# Shell expands "$SERVER" in the parent before this script runs, so a bare
# `starburst ... --server "$SERVER"` fails unless the user sourced .env first.
# Inject connection flags from .env for SEP-backed subcommands when omitted.
extra=()
if [[ $# -ge 2 && "$1" == "data-product" ]]; then
  case "$2" in
    import|export|publish|delete)
      has_server=0
      has_user=0
      has_role=0
      for a in "$@"; do
        case "$a" in
          --server | --server=*) has_server=1 ;;
          --user | --user=*) has_user=1 ;;
          --role | --role=*) has_role=1 ;;
        esac
      done
      [[ "$has_server" -eq 0 && -n "${SERVER:-}" ]] && extra+=(--server="$SERVER")
      [[ "$has_user" -eq 0 && -n "${STARBURST_USER:-}" ]] && extra+=(--user="$STARBURST_USER")
      [[ "$has_role" -eq 0 && -n "${ROLE:-}" ]] && extra+=(--role="$ROLE")
      ;;
  esac
fi

if ((${#extra[@]})); then
  exec java -jar "$CLI_JAR" "$@" "${extra[@]}"
else
  exec java -jar "$CLI_JAR" "$@"
fi
